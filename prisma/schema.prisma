// LifeFlow data model.
// Covers: auth, chat, tasks, reminders, semantic memory, usage/tier tracking.
// Account/Session/VerificationToken are dead weight now that auth is a plain
// JWT issued by this backend (NextAuth is gone) — left in place rather than
// risking a migration to drop them in this pass.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  timezone       String  @default("UTC")
  wakeTime       String  @default("07:00")
  primaryMode    Mode    @default(PROFESSIONAL)
  tier           Tier    @default(FREE)

  messagesUsedThisMonth Int      @default(0)
  imageAnalysesUsed     Int      @default(0)
  usageResetAt          DateTime @default(now())

  onboardedAt DateTime?

  notifyInApp Boolean @default(true)
  notifyEmail Boolean @default(false)
  notifySms   Boolean @default(false)
  notifyPush  Boolean @default(true)
  quietHoursStart String?
  quietHoursEnd   String?

  accounts          Account[]
  sessions          Session[]
  conversations     Conversation[]
  tasks             Task[]
  reminders         Reminder[]
  memories          Memory[]
  integrations      Integration[]
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Mode {
  PROFESSIONAL
  PARENT
  SENIOR
  STUDENT
  SOLOPRENEUR
}

enum Tier {
  FREE
  PERSONAL
  FAMILY
  PROFESSIONAL
  ENTERPRISE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Chat ----------

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New conversation")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String       @db.Text
  imageUrl       String?
  createdAt      DateTime     @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ---------- Tasks & Reminders ----------

model Task {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?    @db.Text
  status         TaskStatus @default(PENDING)
  priority       Priority   @default(MEDIUM)
  dueDate        DateTime?
  sourceMessageId String?
  reminders      Reminder[]

  // One level of subtask nesting only (enforced in the API, not here).
  parentId String?
  parent   Task?   @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("TaskSubtasks")

  // Recurrence: recurrenceParentId always points at the series root, giving
  // every generated instance a stable lineage key for idempotency checks.
  recurrenceInterval  RecurrenceInterval?
  recurrenceParentId  String?
  recurrenceParent    Task?               @relation("TaskRecurrence", fields: [recurrenceParentId], references: [id], onDelete: SetNull)
  recurrenceInstances Task[]              @relation("TaskRecurrence")

  shareToken String?   @unique
  sharedAt   DateTime?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId, parentId])
  @@index([recurrenceParentId])
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Reminder {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  title     String
  remindAt  DateTime
  channel   ReminderChannel @default(IN_APP)
  sent      Boolean         @default(false)
  createdAt DateTime        @default(now())
}

enum ReminderChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// ---------- Semantic Memory ----------
// embedding stored as Float[] for MVP; migrate to a pgvector `Unsupported("vector(1536)")`
// column + HNSW index once real embeddings are wired in.

model Memory {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String         @db.Text
  category   MemoryCategory @default(FACT)
  confidence Float          @default(0.8)
  embedding  Float[]        @default([])
  createdAt  DateTime       @default(now())
}

enum MemoryCategory {
  PREFERENCE
  FACT
  RELATIONSHIP
  CONTEXT
}

// ---------- Integrations (stub) ----------

model Integration {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([userId, provider])
}
